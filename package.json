{
    "name": "vibe-engine",
    "version": "1.0.0",
    "description": "VibeEngine 🌊 - TypeScript ECS Game Engine with Visual Editor",
    "author": {
        "name": "HEK Interactive",
        "email": "hek.interactive@gmail.com",
        "url": "https://hekinteractive.com"
    },
    "copyright": "Copyright © 2025 HEK Interactive",
    "license": "SEE LICENSE FILE",
    "type": "commonjs",
    "main": "electron-main/main.cjs",
    "scripts": {
        "start": "npm run electron:dev",
        "lint": "eslint src --fix",
        "lint:check": "eslint src",
        "dev": "vite",
        "test": "vitest",
        "test:coverage": "vitest run --coverage",
        "build": "tsc && vite build",
        "preview": "vite preview",
        "build:protected": "npm run build && npm run obfuscate",
        "obfuscate": "javascript-obfuscator dist --output dist-protected --config obfuscator.config.json",
        "electron": "npm run build && electron .",
        "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
        "package": "npm run build:protected && electron-builder",
        "package:win": "npm run build:protected && electron-builder --win",
        "pack:sdk": "npm run build:protected && npm pack"
    },
    "dependencies": {
        "@dimforge/rapier3d-compat": "^0.19.3",
        "@monaco-editor/react": "^4.7.0",
        "@types/howler": "^2.2.12",
        "framer-motion": "^12.38.0",
        "howler": "^2.2.4",
        "i18next": "^26.0.3",
        "i18next-browser-languagedetector": "^8.2.1",
        "react-i18next": "^17.0.2",
        "three": "^0.160.0",
        "ts-morph": "^27.0.2",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/react": "^16.3.2",
        "@types/node": "^20.10.0",
        "@types/react": "^18.2.0",
        "@types/react-dom": "^18.2.0",
        "@types/three": "^0.160.0",
        "@vitejs/plugin-react": "^4.2.0",
        "@vitest/coverage-v8": "^4.1.2",
        "concurrently": "^8.2.0",
        "electron": "^28.3.3",
        "electron-builder": "^24.9.0",
        "electron-reload": "^2.0.0-alpha.1",
        "eslint": "^10.2.0",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.0.1",
        "globals": "^17.4.0",
        "happy-dom": "^20.8.9",
        "javascript-obfuscator": "^4.1.0",
        "jsdom": "^29.0.1",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "typescript": "^5.3.0",
        "typescript-eslint": "^8.58.0",
        "vite": "^5.0.0",
        "vitest": "^4.1.2",
        "wait-on": "^7.2.0",
        "zustand": "^4.4.0"
    },
    "build": {
        "appId": "com.hekinteractive.vibeengine",
        "productName": "VibeEngine",
        "buildVersion": "1.0.0",
        "directories": {
            "output": "release",
            "buildResources": "assets"
        },
        "files": [
            "dist/**/*",
            "electron/**/*"
        ],
        "win": {
            "target": [
                {
                    "target": "portable",
                    "arch": [
                        "x64"
                    ]
                }
            ],
            "icon": "assets/icon1.png",
            "publisherName": "HEK Interactive"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "installerIcon": "assets/icon1.png",
            "uninstallerIcon": "assets/icon1.png",
            "installerHeaderIcon": "assets/icon1.png",
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true,
            "shortcutName": "VibeEngine Standalone",
            "license": "LICENSE"
        },
        "asar": false,
        "asarUnpack": [
            "**/*.dll",
            "**/*.node"
        ],
        "extraMetadata": {
            "homepage": "https://hekinteractive.com",
            "author": {
                "name": "HEK Interactive",
                "email": "hek.interactive@gmail.com"
            }
        }
    }
}
